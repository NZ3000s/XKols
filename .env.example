# X (Twitter) API — Consumer Key та Consumer Secret з developer portal
# Скопіюй цей файл як .env і встав свої значення. .env не комітити в git.

X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here

# Опційно: для історичних твітів (старші за 7 днів) через TwitterAPI.io
# https://twitterapi.io/ — pay-as-you-go, підтримує since:/until:
# TWITTERAPI_IO_API_KEY=your_twitterapi_io_key
